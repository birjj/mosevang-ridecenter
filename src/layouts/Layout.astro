---
import Header from "../components/Header.astro";
import DesktopNavbar from "../components/DesktopNavbar.astro";
import MobileNavbar from "../components/MobileNavbar.astro";

interface Props {
  title: string;
}
const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="title" content="Mosevang Ridecenter" />
    <meta
      name="description"
      content="Mosevang Ridecenter er et nybygget privat ridecenter i Fangel, lige syd for Odense."
    />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <main>
      <Header />
      <DesktopNavbar />
      <MobileNavbar />
      <div class="content">
        <slot />
      </div>
    </main>
  </body>
</html>
<style is:global>
  :root {
    --c-background-0: 255 255 255;
    --c-background-1: 221 221 221;
    --c-background-2: 238 238 238;
    --c-foreground-0: 51 51 51;
    --c-foreground-1: 0 0 0;
    --font-family: "lato", sans-serif;
  }
  html,
  body {
    margin: 0;
    min-height: 100vh;
    background: rgb(var(--c-background-1, 221 221 221));
    font-size: 12pt;
    line-height: 1.428571429;
    font-family: var(--font-family, sans-serif);
    color: rgb(var(--c-foreground-0, 51 51 51));
  }

  main {
    background: rgb(var(--c-background-0, 255 255 255));
    box-shadow: 0 0 15px rgb(0 0 0 / 10%);
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    min-height: 100vh;
  }
  .content {
    padding: 15px 60px 60px;
  }

  @media (min-width: 768px) {
    main {
      width: 750px;
    }
  }
  @media (min-width: 992px) {
    main {
      width: 970px;
    }
  }
  @media (min-width: 1200px) {
    main {
      width: 1170px;
    }
  }
  @media (max-width: 600px) {
    .content {
      padding: 15px;
    }
  }
</style>
